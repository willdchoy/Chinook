{
  "name": "infra",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:apply": "pnpm localstack:start && pnpm tf:format && pnpm dev:init && pnpm dev:apply:assumed-role && pnpm dev:apply:core",
    "dev:apply:assumed-role": "./scripts/dev-apply-assume-role.sh",
    "dev:apply:core": "./scripts/dev-apply-core.sh",
    "dev:destroy": "pnpm localstack:stop && pnpm tf:delete",
    "dev:init": "pnpm tf:delete && ./scripts/dev-init.sh",
    "dev:plan": "./scripts/dev-plan.sh",
    "prod:apply": "pnpm tf:format && pnpm prod:init && pnpm prod:apply:assumed-role && pnpm prod:apply:core",
    "prod:apply:assumed-role": "./scripts/prod-apply-assume-role.sh",
    "prod:apply:core": "./scripts/prod-apply-core.sh",
    "prod:destroy": "./scripts/prod-destroy.sh && pnpm tf:delete",
    "prod:init": "pnpm tf:delete && ./scripts/prod-init.sh",
    "prod:plan": "./scripts/prod-plan.sh",
    "tf:delete": "./scripts/tf-delete.sh",
    "tf:format": "terraform fmt --recursive",
    "tf:reset": "pnpm localstack:stop && pnpm tf:delete",
    "localstack:stop": "./scripts/localstack-stop.sh",
    "localstack:start": "./scripts/localstack-start.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.6.2"
}
