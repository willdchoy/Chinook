{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint -c ./.oxfmtrc.json",
    "lint:fix": "pnpm lint --fix",
    "fmt": "oxfmt -c ./.oxfmtrc.json",
    "fmt:check": "pnpm fmt --check"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.9.1",
    "compiler@^5.0.0": "link:svelte/compiler@^5.0.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.7"
  }
}
