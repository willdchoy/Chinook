prometheus.exporter.unix "ch_api_web_prom" {}

prometheus.scrape "ch_api_web_prom" {
    scrape_interval = "10s"

    targets    = prometheus.exporter.unix.ch_api_web.targets
    forward_to = [
        prometheus.remote_write.ch_api_web_prom.receiver,
    ]
}

prometheus.remote_write "ch_api_web_prom" {
    endpoint {
        url = "http://prometheus:9090/api/v1/write"
    }
}