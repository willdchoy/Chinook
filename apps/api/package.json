{
  "name": "@chinook/api",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "imports": {
    "#app/*.ts": "./src/*.ts",
    "#features/*.ts": "./src/features/*.ts",
    "#common/*.ts": "./src/common/*.ts",
    "#middleware": "./src/middleware/index.ts"
  },
  "scripts": {
    "dev": "pnpm db:migrate && PORT=8000 node --watch --env-file=.env ./src/server.ts >> /var/log/ch-client-app.log 2> /var/log/ch-client-err.log",
    "log": "ch-client-app.log &>> ch-client-err.log",
    "createTLS": "openssl req -x509 -nodes -days 365 -newkey rsa:2048 -keyout localhost.key -out localhost.crt -subj \"/CN=localhost\" -extensions EXT -config <(printf \"[dn]\nCN=localhost\n[req]\ndistinguished_name = dn\n[EXT]\nsubjectAltName=DNS:localhost,IP:192.168.1.134\nkeyUsage=digitalSignature\nextendedKeyUsage=serverAuth\")",
    "db:migrate": "node --env-file=.env ./scripts/migrations/migrate.ts >> /var/log/ch-client-app.log 2> /var/log/ch-client-err.log",
    "db:psql": "psql -p 5432 -h localhost -U admin -d chinook",
    "db:start": "pnpm --dir ../db run db:start && sleep 3s && pnpm db:migrate",
    "db:destroy": "pnpm --dir ../db run db:destroy",
    "test": "node --test ./src/**/*.spec.ts",
    "test:watch": "node --test --watch ./src/**/*.spec.ts",
    "lint": "oxlint",
    "lint:watch": "oxlint --watch",
    "fmt": "oxfmt",
    "fmt:fix": "oxfmt --fix"
  },
  "dependencies": {
    "pg": "^8.16.3",
    "postgrator": "^8.0.0"
  },
  "devDependencies": {
    "@types/autocannon": "^7.12.7",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.16.0",
    "autocannon": "^8.0.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.3"
  },
  "packageManager": "pnpm@10.6.2"
}
