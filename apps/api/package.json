{
  "name": "@chinook/api",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "imports": {
    "#app/*.ts": "./src/*.ts",
    "#features/*.ts": "./src/features/*.ts",
    "#common/*.ts": "./src/common/*.ts",
    "#middleware": "./src/middleware/index.ts"
  },
  "scripts": {
    "dev": "pnpm db:migrate && node --watch --env-file=.env ./src/server.ts",
    "db:migrate": "node --env-file=.env ./scripts/migrations/migrate.ts",
    "db:psql": "psql -p 5432 -h localhost -U admin -d chinook",
    "db:start": "pnpm --dir ../db run db:start && sleep 3s && pnpm db:migrate",
    "db:destroy": "pnpm --dir ../db run db:destroy",
    "test": "node --test ./src/**/*.spec.ts",
    "test:watch": "node --test --watch ./src/**/*.spec.ts",
    "test:benchmark": "node --test --watch ./src/**/*.benchmark.ts",
    "benchmark": "npx autocannon -c 90 -d 10 -p 1 https://localhost:8000/albums",
    "lint": "oxlint",
    "lint:watch": "oxlint --watch",
    "fmt": "oxfmt",
    "fmt:fix": "oxfmt --fix"
  },
  "dependencies": {
    "pg": "^8.16.3",
    "postgrator": "^8.0.0"
  },
  "devDependencies": {
    "@types/autocannon": "^7.12.7",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.16.0",
    "autocannon": "^8.0.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.3"
  },
  "packageManager": "pnpm@10.6.2"
}
