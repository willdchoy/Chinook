#!/bin/bash

function get_to_the_choppa() {
  echo
cat << "EOF"
                                         /\
                                        /  \
               -----------!----------- /    \
----------!----------  /=====\        /  /\  \
        |===\_________/__o___|   /\  /  /  \  \
       /_]    o o o o  ___  /   /  \/  /    \  \
\/\   <_]__[]_________<___>/   /    \ /      \  \
/  \      o             o     /      \        \  \
...................................................
EOF
  echo
  echo -e "\033[1;32mChinook - Get to the Choppa! \033[0m"
  echo
}

function handle_stats() {
  docker stats
}

function handle() {
  filename=$1
  if [[ "$2" == "restart" ]]; then
      docker-compose -f docker-compose-${filename}.yml down $3
      docker-compose -f docker-compose-${filename}.yml up -d $3
  elif [[ "$2" == "up" ]]; then
    docker-compose -f docker-compose-${filename}.yml up -d $3
  elif [[ "$2" == "down" ]]; then  
    docker-compose -f docker-compose-${filename}.yml down $3
  fi
}

get_to_the_choppa

case "$1" in
  up)
    handle client up && handle obsvr up
    ;;
  down)
    handle client down && handle obsvr down
    ;;
  client)
    handle "$@"
    ;;
  obsvr)
    handle "$@"
    ;;
  stats)
    handle_stats
    ;;
  *)
    echo "Invalid option"
    echo -e "${error_message}"
    exit 1
esac
