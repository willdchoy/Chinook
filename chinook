#!/bin/bash

obsvr_network=ch-obsvr
client_network=ch-client

# core --------------------------------------------------------

function get_to_da_choppa() {
  echo
cat << "EOF"
                                         /\
                                        /  \
               -----------!----------- /    \
----------!----------  /=====\        /  /\  \
        |===\_________/__o___|   /\  /  /  \  \
       /_]    o o o o  ___  /   /  \/  /    \  \
\/\   <_]__[]_________<___>/   /    \ /      \  \
/  \      o             o     /      \        \  \
...................................................
EOF
  echo
  echo -e "\033[1;32mChinook - Get to the Choppa! \033[0m"
  echo
}

function destroy_network() {
  echo -e "\033[1;32mChinook - Destroying network $1.., \033[0m"
  if [[ ! $(docker network ls | grep -w $1) ]]; then
    echo ""
  else
    docker network rm $1
    echo
  fi
}

function create_network() {
  echo -e "\033[1;32mChinook - Creating network $1... \033[0m"
  if [[ $(docker network ls | grep -w $1) ]]; then
    echo "$1 network already exits."
    echo ""   
  else 
    docker network create $1 \
      --attachable \
      -d bridge \
      --subnet $2 || true
    echo
  fi
}

# client --------------------------------------------------------

function destroy_docker_registry() {
  echo -e "\033[1;32mChinook - Destroying docker registry... \033[0m"
  docker rm -f ch-regi
  echo
}

function create_docker_registry() {
  destroy_docker_registry
  echo -e "\033[1;32mChinook - Creating docker registry... \033[0m"
  docker compose -v -f ./docker/docker-compose-regi.yml up -d
  echo
}

function create_client_images() {
  echo -e "\033[1;32mChinook - Building and deploy images to docker registry... \033[0m"
  make -C ./docker/ch-base docker-build
  make -C ./apps/api docker-build
  make -C ./apps/db docker-build
  echo
}

function create_client_containers() {
  echo -e "\033[1;32mChinook - Composing client containers... \033[0m"
  docker compose -f ./docker/docker-compose-web.yml up -d
  echo 
}

function client_seed() {
  echo -e "\033[1;32mChinook - Seeding database... \033[0m"
  make -C ./apps/db docker-seed
  echo
}

function destroy_client_containers() {
  echo -e "\033[1;32mChinook - Stopping and removing client containers... \033[0m"
  docker rm -f ch-api-web ch-db-pg
  echo
}

function destroy_client_images() {
  echo -e "\033[1;32mChinook - Removing images... \033[0m"
  docker rmi localhost:5000/ch/base:latest localhost:5000/ch/api-web:latest localhost:5000/ch/db-pg:latest
  echo
}

# obsvr --------------------------------------------------------

function create_obsvr_containers() {
  echo -e "\033[1;32mChinook - Composing Obsvr containers... \033[0m"
  docker compose -f ./docker/docker-compose-obsvr.yml up -d
  echo
}

function destroy_obsvr_images() {
  echo -e "\033[1;32mChinook - Removing images... \033[0m"
  docker rmi grafana/grafana:latest grafana/loki:latest prom/prometheus:latest
  echo
}

function destroy_obsvr_containers() {
  echo -e "\033[1;32mChinook - Stopping and removing obsvr containers... \033[0m"
  docker rm -f -v ch-graf ch-loki ch-prom
  echo
}


# case handlers --------------------------------------------------------

function destroy_client() {
  destroy_client_containers
  destroy_client_images
}

function create_client() {
  destroy_client
  create_client_images
  create_client_containers
  client_seed
}

function destroy_obsvr() {
  destroy_obsvr_containers
  destroy_network "${obsvr_network}"
}

function create_obsvr() {
  destroy_obsvr
  create_network "${obsvr_network}" "172.18.2.0/24"
  create_obsvr_containers
}

function destroy_all() {
  destroy_obsvr_containers
  destroy_network "${obsvr_network}"
  destroy_docker_registry
  destroy_client_containers
  destroy_client_images
  destroy_network "${client_network}"
}

# handle init --------------------------------------------------------

args=("destroy destroy_client destroy_obsvr client obsvr regi start")
error_message="\033[1;31mChinook - Argument of < ${args} > is required! \033[0m"

# vaidate argument
if [[ ! $(echo ${args[@]} | fgrep -w $1) ]]; then
    echo -e ${error_message}
    exit 1
fi

get_to_da_choppa

if [[ ! $1 == 'destroy' ]]; then
  create_network "${client_network}"  "172.18.1.0/24"
fi

case "$1" in
  destroy)
    destroy_all
    ;;
  destroy_client)
    destroy_client
    ;;
  destroy_obsvr)
    destroy_obsvr
    ;;
  client)
    create_client
    ;;
  obsvr)
    create_obsvr
    ;;
  regi)
    create_docker_registry
    ;;
  start)
    create_docker_registry
    create_client
    create_obsvr
    ;;
  *)
    echo -e "${error_message}"
    exit 1
esac